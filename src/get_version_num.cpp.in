#include "get_version_num.h"


unsigned
GetVersionMajor ()
{
	return @kcbfin_VERSION_MAJOR@ +0;
}


unsigned
GetVersionMinor ()
{
	return @kcbfin_VERSION_MINOR@ +0;
}


unsigned
GetVersionPatch ()
{
	return @kcbfin_VERSION_PATCH@ +0;
}


unsigned
GetNumCommits ()
{
	return @kcbfin_NUM_COMMITS@ +0;
}
